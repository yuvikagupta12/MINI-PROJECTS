import tkinter as tk
from tkinter import messagebox

cart = {}

# Add Item
def add_item():
    try:
        item = item_entry.get()
        price = float(price_entry.get())
        quantity = int(quantity_entry.get())

        cart[item] = [price, quantity]

        messagebox.showinfo("Success", "Item Added Successfully!")

        item_entry.delete(0, tk.END)
        price_entry.delete(0, tk.END)
        quantity_entry.delete(0, tk.END)

    except ValueError:
        messagebox.showerror("Error", "Enter valid price and quantity!")

# View Cart
def view_cart():
    cart_list.delete(0, tk.END)

    total = 0

    for item, details in cart.items():
        price, quantity = details
        subtotal = price * quantity
        total += subtotal

        cart_list.insert(
            tk.END,
            f"{item} | ₹{price} x {quantity} = ₹{subtotal}"
        )

    total_label.config(text=f"Grand Total: ₹{total}")

# Remove Item
def remove_item():
    item = item_entry.get()

    if item in cart:
        del cart[item]
        messagebox.showinfo("Success", "Item Removed!")
        view_cart()
    else:
        messagebox.showerror("Error", "Item Not Found!")

# Checkout
def checkout():
    total = 0

    for price, quantity in cart.values():
        total += price * quantity

    messagebox.showinfo(
        "Checkout",
        f"Total Bill: ₹{total}\nThank You For Shopping!"
    )

# GUI Window
root = tk.Tk()
root.title("Shopping Cart System")
root.geometry("550x500")

tk.Label(root, text="Shopping Cart System",
         font=("Arial", 16, "bold")).pack(pady=10)

tk.Label(root, text="Item Name").pack()
item_entry = tk.Entry(root, width=30)
item_entry.pack()

tk.Label(root, text="Price").pack()
price_entry = tk.Entry(root, width=30)
price_entry.pack()

tk.Label(root, text="Quantity").pack()
quantity_entry = tk.Entry(root, width=30)
quantity_entry.pack()

tk.Button(root, text="Add Item",
          command=add_item, width=20).pack(pady=5)

tk.Button(root, text="View Cart",
          command=view_cart, width=20).pack(pady=5)

tk.Button(root, text="Remove Item",
          command=remove_item, width=20).pack(pady=5)

tk.Button(root, text="Checkout",
          command=checkout, width=20).pack(pady=5)

cart_list = tk.Listbox(root, width=65, height=12)
cart_list.pack(pady=10)

total_label = tk.Label(root,
                       text="Grand Total: ₹0",
                       font=("Arial", 12, "bold"))
total_label.pack(pady=10)

root.mainloop()
